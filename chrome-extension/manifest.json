{
  "manifest_version": 3,
  "name": "Activity Monitor — Browser Tracker",
  "version": "1.0.0",
  "description": "Tracks active tab URL, title, and time spent. Sends data to your Activity Monitor dashboard.",
  "permissions": [
    "tabs",
    "alarms",
    "storage",
    "idle"
  ],
  "host_permissions": [
    "https://activity-monitor-qmx3.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
